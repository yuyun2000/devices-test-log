+/*
+ * SPDX-FileCopyrightText: 2026 Espressif Systems (Shanghai) CO LTD
+ *
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+#include "button_gpio.h"
+#include "bsp_err_check.h"
+#include "bsp/m5stack_stopwatch.h"
+
+esp_err_t bsp_iot_button_create(button_handle_t btn_array[], int *btn_cnt, int btn_array_size)
+{
+    if (btn_array == NULL || btn_array_size < BSP_BUTTON_NUM) {
+        return ESP_ERR_INVALID_ARG;
+    }
+
+    const button_config_t button_config = {0};
+    const button_gpio_config_t gpio_config[BSP_BUTTON_NUM] = {
+        [BSP_BUTTON_A] = {
+            .gpio_num = BSP_BUTTON_A_IO,
+            .active_level = 0,
+        },
+        [BSP_BUTTON_B] = {
+            .gpio_num = BSP_BUTTON_B_IO,
+            .active_level = 0,
+        },
+    };
+
+    for (int i = 0; i < BSP_BUTTON_NUM; ++i) {
+        BSP_ERROR_CHECK_RETURN_ERR(iot_button_new_gpio_device(&button_config, &gpio_config[i], &btn_array[i]));
+    }
+    if (btn_cnt != NULL) {
+        *btn_cnt = BSP_BUTTON_NUM;
+    }
+    return ESP_OK;
+}
diff --git a/bsp/m5stack_stopwatch/src/bsp_control.c b/bsp/m5stack_stopwatch/src/bsp_control.c
new file mode 100644
index 0000000..a8b0588
--- /dev/null
+++ b/bsp/m5stack_stopwatch/src/bsp_control.c
@@ -0,0 +1,385 @@
+/*
+ * SPDX-FileCopyrightText: 2026 Espressif Systems (Shanghai) CO LTD
+ *
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+#include <string.h>
+
+#include "freertos/FreeRTOS.h"
+#include "freertos/task.h"
+#include "driver/gpio.h"
+#include "esp_check.h"
+#include "esp_log.h"
+
+#include "bsp/m5stack_stopwatch.h"
+#include "bsp_stopwatch_internal.h"
+
+#define M5PM1_REG_POWER_SOURCE       0x04
+#define M5PM1_REG_POWER_CONFIG       0x06
+#define M5PM1_REG_POWER_HOLD         0x07
+#define M5PM1_REG_I2C_CONFIG         0x09
+#define M5PM1_REG_WATCHDOG           0x0A
+#define M5PM1_REG_GPIO_MODE           0x10
+#define M5PM1_REG_GPIO_OUT            0x11
+#define M5PM1_REG_GPIO_DRIVE          0x13
+#define M5PM1_REG_GPIO_PULL_0         0x14
+#define M5PM1_REG_GPIO_FUNC_0         0x16
+#define M5PM1_REG_VBAT_LOW           0x22
+#define M5PM1_REG_VIN_LOW            0x24
+#define M5PM1_REG_BUTTON_CONFIG       0x49
+#define M5PM1_POWER_REQUIRED_MASK     0x07
+#define M5PM1_LDO_HOLD_MASK           BIT(5)
+#define M5PM1_CHARGE_STATUS_GPIO      2
+#define M5PM1_CHARGE_PROGRAM_GPIO     3
+#define M5PM1_BUTTON_CLICK_1S_MASK    0x06
+#define M5PM1_SINGLE_RESET_DISABLE    BIT(0)
+
+#define M5IOE1_REG_GPIO_MODE_LOW     0x03
+#define M5IOE1_REG_GPIO_OUT_LOW      0x05
+#define M5IOE1_REG_GPIO_IN_LOW       0x07
+#define M5IOE1_REG_GPIO_DRIVE_LOW    0x13
+#define M5IOE1_REG_PWM1_DUTY_LOW     0x1B
+#define M5IOE1_REG_I2C_CONFIG        0x23
+#define M5IOE1_REG_PWM_FREQ_LOW      0x25
+#define M5IOE1_PWM_ENABLE            0x80
+
+#define STOPWATCH_SPEAKER_PA_GPIO    GPIO_NUM_14
+
+static const char *TAG = "M5Stack StopWatch";
+static i2c_master_dev_handle_t pmic_handle;
+static i2c_master_dev_handle_t ioe_handle;
+static uint8_t ioe_address;
+static bool control_initialized;
+
+static esp_err_t device_read(i2c_master_dev_handle_t device, uint8_t reg, void *data, size_t size)
+{
+    return i2c_master_transmit_receive(device, &reg, sizeof(reg), data, size, 100);
+}
+
+static esp_err_t device_write(i2c_master_dev_handle_t device, uint8_t reg, const void *data, size_t size)
+{
+    uint8_t buffer[5];
+    ESP_RETURN_ON_FALSE(size <= sizeof(buffer) - 1, ESP_ERR_INVALID_SIZE, TAG, "I2C write is too large");
+    buffer[0] = reg;
+    if (size > 0) {
+        memcpy(&buffer[1], data, size);
+    }
+    return i2c_master_transmit(device, buffer, size + 1, 100);
+}
+
+static esp_err_t device_write_u8(i2c_master_dev_handle_t device, uint8_t reg, uint8_t value)
+{
+    return device_write(device, reg, &value, sizeof(value));
+}
+
+static esp_err_t device_read_u8(i2c_master_dev_handle_t device, uint8_t reg, uint8_t *value)
+{
+    return device_read(device, reg, value, sizeof(*value));
+}
+
+static esp_err_t device_update_u8(i2c_master_dev_handle_t device, uint8_t reg,
+                                  uint8_t clear_mask, uint8_t set_mask)
+{
+    uint8_t value;
+    ESP_RETURN_ON_ERROR(device_read_u8(device, reg, &value), TAG, "I2C read-modify-write failed");
+    value = (value & ~clear_mask) | set_mask;
+    return device_write_u8(device, reg, value);
+}
+
+static esp_err_t device_read_u16(i2c_master_dev_handle_t device, uint8_t reg, uint16_t *value)
+{
+    uint8_t data[2];
+    ESP_RETURN_ON_ERROR(device_read(device, reg, data, sizeof(data)), TAG, "I2C read failed");
+    *value = (uint16_t)data[0] | ((uint16_t)data[1] << 8);
+    return ESP_OK;
+}
+
+static esp_err_t device_write_u16(i2c_master_dev_handle_t device, uint8_t reg, uint16_t value)
+{
+    const uint8_t data[] = { value & 0xFF, value >> 8 };
+    return device_write(device, reg, data, sizeof(data));
+}
+
+static esp_err_t add_device_at_speed(uint8_t address, uint32_t speed_hz, i2c_master_dev_handle_t *ret_handle)
+{
+    const i2c_device_config_t config = {
+        .dev_addr_length = I2C_ADDR_BIT_LEN_7,
+        .device_address = address,
+        .scl_speed_hz = speed_hz,
+    };
+    ESP_RETURN_ON_ERROR(i2c_master_bus_add_device(bsp_i2c_get_handle(), &config, ret_handle), TAG,
+                        "Failed to add I2C device 0x%02X", address);
+
+    uint8_t id;
+    esp_err_t ret = ESP_FAIL;
+    for (int attempt = 0; attempt < 3; ++attempt) {
+        ret = device_read_u8(*ret_handle, 0x00, &id);
+        if (ret == ESP_OK) {
+            return ESP_OK;
+        }
+        vTaskDelay(pdMS_TO_TICKS(10));
+    }
+
+    i2c_master_bus_rm_device(*ret_handle);
+    *ret_handle = NULL;
+    return ret;
+}
+
+static esp_err_t add_device(uint8_t address, i2c_master_dev_handle_t *ret_handle)
+{
+    esp_err_t ret = add_device_at_speed(address, 100000, ret_handle);
+    if (ret == ESP_OK) {
+        return ESP_OK;
+    }
+    return add_device_at_speed(address, 400000, ret_handle);
+}
+
+static esp_err_t ioe_set_output(uint8_t pin_number, bool high)
+{
+    ESP_RETURN_ON_FALSE(pin_number >= 1 && pin_number <= 14, ESP_ERR_INVALID_ARG, TAG, "Invalid M5IOE1 pin");
+    uint16_t output;
+    ESP_RETURN_ON_ERROR(device_read_u16(ioe_handle, M5IOE1_REG_GPIO_OUT_LOW, &output), TAG,
+                        "Failed to read M5IOE1 output");
+    const uint16_t mask = (uint16_t)1U << (pin_number - 1);
+    output = high ? (output | mask) : (output & ~mask);
+    return device_write_u16(ioe_handle, M5IOE1_REG_GPIO_OUT_LOW, output);
+}
+
+static esp_err_t configure_pmic(void)
+{
+    ESP_RETURN_ON_ERROR(device_update_u8(pmic_handle, M5PM1_REG_I2C_CONFIG, 0x0F, 0), TAG,
+                        "Failed to disable M5PM1 I2C sleep");
+    ESP_RETURN_ON_ERROR(device_write_u8(pmic_handle, M5PM1_REG_WATCHDOG, 0), TAG,
+                        "Failed to disable M5PM1 watchdog");
+    ESP_RETURN_ON_ERROR(device_update_u8(pmic_handle, M5PM1_REG_POWER_CONFIG, 0,
+                                         M5PM1_POWER_REQUIRED_MASK), TAG,
+                        "Failed to enable M5PM1 power rails and charging");
+    ESP_RETURN_ON_ERROR(device_update_u8(pmic_handle, M5PM1_REG_POWER_HOLD, 0,
+                                         M5PM1_LDO_HOLD_MASK), TAG,
+                        "Failed to retain the M5PM1 LDO for RTC power");
+    ESP_RETURN_ON_ERROR(device_update_u8(pmic_handle, M5PM1_REG_BUTTON_CONFIG, 0x07,
+                                         M5PM1_BUTTON_CLICK_1S_MASK | M5PM1_SINGLE_RESET_DISABLE), TAG,
+                        "Failed to configure the M5PM1 power button");
+
+    const uint8_t charge_gpio_func_mask = 0x03 << (M5PM1_CHARGE_STATUS_GPIO * 2) |
+                                          0x03 << (M5PM1_CHARGE_PROGRAM_GPIO * 2);
+    const uint8_t charge_gpio_mask = BIT(M5PM1_CHARGE_STATUS_GPIO) | BIT(M5PM1_CHARGE_PROGRAM_GPIO);
+    ESP_RETURN_ON_ERROR(device_update_u8(pmic_handle, M5PM1_REG_GPIO_FUNC_0,
+                                         charge_gpio_func_mask, 0), TAG,
+                        "Failed to select M5PM1 charge GPIO functions");
+    ESP_RETURN_ON_ERROR(device_update_u8(pmic_handle, M5PM1_REG_GPIO_OUT,
+                                         BIT(M5PM1_CHARGE_PROGRAM_GPIO), 0), TAG,
+                        "Failed to set M5PM1 charge-program output low");
+    ESP_RETURN_ON_ERROR(device_update_u8(pmic_handle, M5PM1_REG_GPIO_PULL_0,
+                                         charge_gpio_func_mask, 0), TAG,
+                        "Failed to disable M5PM1 charge GPIO pulls");
+    ESP_RETURN_ON_ERROR(device_update_u8(pmic_handle, M5PM1_REG_GPIO_DRIVE,
+                                         BIT(M5PM1_CHARGE_PROGRAM_GPIO), 0), TAG,
+                        "Failed to select M5PM1 charge-program push-pull drive");
+    return device_update_u8(pmic_handle, M5PM1_REG_GPIO_MODE, charge_gpio_mask,
+                            BIT(M5PM1_CHARGE_PROGRAM_GPIO));
+}
+
+static esp_err_t configure_io_expander(void)
+{
+    uint8_t i2c_config;
+    ESP_RETURN_ON_ERROR(device_read_u8(ioe_handle, M5IOE1_REG_I2C_CONFIG, &i2c_config), TAG,
+                        "Failed to read M5IOE1 I2C config");
+    i2c_config &= ~0x0F;
+    ESP_RETURN_ON_ERROR(device_write_u8(ioe_handle, M5IOE1_REG_I2C_CONFIG, i2c_config), TAG,
+                        "Failed to disable M5IOE1 I2C sleep");
+
+    const uint16_t controlled_pins = BIT(BSP_IOE_MUX_SELECT - 1) |
+                                     BIT(BSP_IOE_AUDIO_ENABLE - 1) |
+                                     BIT(BSP_IOE_TOUCH_RESET - 1) |
+                                     BIT(BSP_IOE_DISPLAY_RESET - 1) |
+                                     BIT(BSP_IOE_DISPLAY_ENABLE - 1) |
+                                     BIT(BSP_IOE_VIBRATION - 1) |
+                                     BIT(BSP_IOE_SPEAKER_ENABLE - 1);
+
+    uint16_t output;
+    ESP_RETURN_ON_ERROR(device_read_u16(ioe_handle, M5IOE1_REG_GPIO_OUT_LOW, &output), TAG,
+                        "Failed to read M5IOE1 output state");
+    output &= ~controlled_pins;
+    output |= BIT(BSP_IOE_AUDIO_ENABLE - 1) |
+              BIT(BSP_IOE_TOUCH_RESET - 1) |
+              BIT(BSP_IOE_DISPLAY_RESET - 1) |
+              BIT(BSP_IOE_DISPLAY_ENABLE - 1);
+    ESP_RETURN_ON_ERROR(device_write_u16(ioe_handle, M5IOE1_REG_GPIO_OUT_LOW, output), TAG,
+                        "Failed to set M5IOE1 output state");
+
+    uint16_t drive;
+    ESP_RETURN_ON_ERROR(device_read_u16(ioe_handle, M5IOE1_REG_GPIO_DRIVE_LOW, &drive), TAG,
+                        "Failed to read M5IOE1 drive state");
+    drive &= ~controlled_pins;
+    ESP_RETURN_ON_ERROR(device_write_u16(ioe_handle, M5IOE1_REG_GPIO_DRIVE_LOW, drive), TAG,
+                        "Failed to set M5IOE1 push-pull outputs");
+
+    uint16_t mode;
+    ESP_RETURN_ON_ERROR(device_read_u16(ioe_handle, M5IOE1_REG_GPIO_MODE_LOW, &mode), TAG,
+                        "Failed to read M5IOE1 GPIO mode");
+    mode |= controlled_pins;
+    ESP_RETURN_ON_ERROR(device_write_u16(ioe_handle, M5IOE1_REG_GPIO_MODE_LOW, mode), TAG,
+                        "Failed to set M5IOE1 GPIO mode");
+
+    ESP_RETURN_ON_ERROR(device_write_u16(ioe_handle, M5IOE1_REG_PWM_FREQ_LOW, 5000), TAG,
+                        "Failed to set vibration PWM frequency");
+    ESP_RETURN_ON_ERROR(device_write_u16(ioe_handle, M5IOE1_REG_PWM1_DUTY_LOW, 0), TAG,
+                        "Failed to disable vibration PWM");
+
+    for (int attempt = 0; attempt < 5; ++attempt) {
+        uint16_t input;
+        ESP_RETURN_ON_ERROR(device_read_u16(ioe_handle, M5IOE1_REG_GPIO_IN_LOW, &input), TAG,
+                            "Failed to read M5IOE1 display power state");
+        if ((input & BIT(BSP_IOE_DISPLAY_ENABLE - 1)) != 0) {
+            break;
+        }
+        ESP_RETURN_ON_ERROR(ioe_set_output(BSP_IOE_DISPLAY_ENABLE, true), TAG,
+                            "Failed to retry M5IOE1 display power enable");
+        vTaskDelay(pdMS_TO_TICKS(80));
+        ESP_RETURN_ON_FALSE(attempt < 4, ESP_ERR_TIMEOUT, TAG, "M5IOE1 display power did not become active");
+    }
+
+    const gpio_config_t speaker_pa_config = {
+        .pin_bit_mask = BIT64(STOPWATCH_SPEAKER_PA_GPIO),
+        .mode = GPIO_MODE_OUTPUT,
+    };
+    ESP_RETURN_ON_ERROR(gpio_config(&speaker_pa_config), TAG, "Failed to configure speaker PA GPIO");
+    return gpio_set_level(STOPWATCH_SPEAKER_PA_GPIO, 0);
+}
+
+esp_err_t bsp_control_init(void)
+{
+    if (control_initialized) {
+        return ESP_OK;
+    }
+
+    ESP_RETURN_ON_ERROR(bsp_i2c_init(), TAG, "Failed to initialize I2C");
+    if (pmic_handle == NULL) {
+        ESP_RETURN_ON_ERROR(add_device(BSP_I2C_M5PM1_ADDRESS, &pmic_handle), TAG, "M5PM1 not found");
+    }
+    ESP_RETURN_ON_ERROR(configure_pmic(), TAG, "Failed to configure M5PM1");
+
+    if (ioe_handle == NULL) {
+        esp_err_t ret = add_device(BSP_I2C_M5IOE1_ADDRESS, &ioe_handle);
+        ioe_address = BSP_I2C_M5IOE1_ADDRESS;
+        if (ret != ESP_OK) {
+            ret = add_device(BSP_I2C_M5IOE1_ADDRESS_ALT, &ioe_handle);
+            ioe_address = BSP_I2C_M5IOE1_ADDRESS_ALT;
+        }
+        ESP_RETURN_ON_ERROR(ret, TAG, "M5IOE1 not found at 0x%02X or 0x%02X",
+                            BSP_I2C_M5IOE1_ADDRESS, BSP_I2C_M5IOE1_ADDRESS_ALT);
+    }
+    ESP_RETURN_ON_ERROR(configure_io_expander(), TAG, "Failed to configure M5IOE1");
+
+    control_initialized = true;
+    ESP_LOGI(TAG, "Control initialized (M5IOE1 address 0x%02X)", ioe_address);
+    return ESP_OK;
+}
+
+uint8_t bsp_io_expander_get_address(void)
+{
+    return ioe_address;
+}
+
+esp_err_t bsp_feature_enable(bsp_feature_t feature, bool enable)
+{
+    ESP_RETURN_ON_ERROR(bsp_control_init(), TAG, "Control initialization failed");
+    switch (feature) {
+    case BSP_FEATURE_LCD:
+        return ioe_set_output(BSP_IOE_DISPLAY_ENABLE, enable);
+    case BSP_FEATURE_TOUCH:
+        return ioe_set_output(BSP_IOE_TOUCH_RESET, enable);
+    case BSP_FEATURE_AUDIO:
+    case BSP_FEATURE_MIC:
+        return ioe_set_output(BSP_IOE_AUDIO_ENABLE, enable);
+    case BSP_FEATURE_SPEAKER:
+        ESP_RETURN_ON_ERROR(ioe_set_output(BSP_IOE_SPEAKER_ENABLE, enable), TAG, "Speaker IOE control failed");
+        ESP_RETURN_ON_ERROR(gpio_set_level(STOPWATCH_SPEAKER_PA_GPIO, enable), TAG, "Speaker PA control failed");
+        vTaskDelay(pdMS_TO_TICKS(10));
+        return ESP_OK;
+    case BSP_FEATURE_USB:
+        return ioe_set_output(BSP_IOE_MUX_SELECT, enable);
+    default:
+        return ESP_ERR_INVALID_ARG;
+    }
+}
+
+esp_err_t bsp_stopwatch_usb_route(bool usb_selected)
+{
+    return bsp_feature_enable(BSP_FEATURE_USB, usb_selected);
+}
+
+esp_err_t bsp_stopwatch_vibration_set(uint8_t strength_percent)
+{
+    ESP_RETURN_ON_FALSE(strength_percent <= 100, ESP_ERR_INVALID_ARG, TAG, "Vibration strength must be 0..100");
+    ESP_RETURN_ON_ERROR(bsp_control_init(), TAG, "Control initialization failed");
+
+    uint16_t duty = 0;
+    uint8_t control = 0;
+    if (strength_percent > 0) {
+        const uint8_t duty_percent = 25 + ((uint16_t)strength_percent * 75) / 100;
+        duty = ((uint32_t)duty_percent * 0x0FFF) / 100;
+        control = M5IOE1_PWM_ENABLE;
+    }
+    const uint8_t data[] = { duty & 0xFF, (duty >> 8) | control };
+    ESP_RETURN_ON_ERROR(device_write(ioe_handle, M5IOE1_REG_PWM1_DUTY_LOW, data, sizeof(data)), TAG,
+                        "Failed to set vibration PWM");
+
+    if (strength_percent > 0) {
+        uint16_t mode;
+        ESP_RETURN_ON_ERROR(device_read_u16(ioe_handle, M5IOE1_REG_GPIO_MODE_LOW, &mode), TAG,
+                            "Failed to read M5IOE1 GPIO mode");
+        mode |= BIT(BSP_IOE_VIBRATION - 1);
+        ESP_RETURN_ON_ERROR(device_write_u16(ioe_handle, M5IOE1_REG_GPIO_MODE_LOW, mode), TAG,
+                            "Failed to enable vibration output");
+    }
+    return ESP_OK;
+}
+
+esp_err_t bsp_stopwatch_display_reset(void)
+{
+    ESP_RETURN_ON_ERROR(bsp_control_init(), TAG, "Control initialization failed");
+    ESP_RETURN_ON_ERROR(ioe_set_output(BSP_IOE_DISPLAY_ENABLE, true), TAG, "Failed to enable display rail");
+    ESP_RETURN_ON_ERROR(ioe_set_output(BSP_IOE_DISPLAY_RESET, false), TAG, "Failed to assert display reset");
+    vTaskDelay(pdMS_TO_TICKS(10));
+    ESP_RETURN_ON_ERROR(ioe_set_output(BSP_IOE_DISPLAY_RESET, true), TAG, "Failed to release display reset");
+    vTaskDelay(pdMS_TO_TICKS(120));
+    return ESP_OK;
+}
+
+esp_err_t bsp_stopwatch_touch_reset(void)
+{
+    ESP_RETURN_ON_ERROR(bsp_control_init(), TAG, "Control initialization failed");
+    ESP_RETURN_ON_ERROR(ioe_set_output(BSP_IOE_TOUCH_RESET, false), TAG, "Failed to assert touch reset");
+    vTaskDelay(pdMS_TO_TICKS(10));
+    ESP_RETURN_ON_ERROR(ioe_set_output(BSP_IOE_TOUCH_RESET, true), TAG, "Failed to release touch reset");
+    vTaskDelay(pdMS_TO_TICKS(50));
+    return ESP_OK;
+}
+
+esp_err_t bsp_stopwatch_get_battery_voltage(uint16_t *millivolts)
+{
+    ESP_RETURN_ON_FALSE(millivolts != NULL, ESP_ERR_INVALID_ARG, TAG, "Battery output is NULL");
+    ESP_RETURN_ON_ERROR(bsp_control_init(), TAG, "Control initialization failed");
+    return device_read_u16(pmic_handle, M5PM1_REG_VBAT_LOW, millivolts);
+}
+
+esp_err_t bsp_stopwatch_get_input_voltage(uint16_t *millivolts)
+{
+    ESP_RETURN_ON_FALSE(millivolts != NULL, ESP_ERR_INVALID_ARG, TAG, "Input output is NULL");
+    ESP_RETURN_ON_ERROR(bsp_control_init(), TAG, "Control initialization failed");
+    return device_read_u16(pmic_handle, M5PM1_REG_VIN_LOW, millivolts);
+}
+
+esp_err_t bsp_stopwatch_get_power_source(bsp_stopwatch_power_source_t *source)
+{
+    ESP_RETURN_ON_FALSE(source != NULL, ESP_ERR_INVALID_ARG, TAG, "Power source output is NULL");
+    ESP_RETURN_ON_ERROR(bsp_control_init(), TAG, "Control initialization failed");
+    uint8_t value;
+    ESP_RETURN_ON_ERROR(device_read_u8(pmic_handle, M5PM1_REG_POWER_SOURCE, &value), TAG,
+                        "Failed to read power source");
+    *source = (bsp_stopwatch_power_source_t)(value & 0x07);
+    return ESP_OK;
+}
diff --git a/bsp/m5stack_stopwatch/src/bsp_display.c b/bsp/m5stack_stopwatch/src/bsp_display.c
new file mode 100644
index 0000000..b4a271a
--- /dev/null
+++ b/bsp/m5stack_stopwatch/src/bsp_display.c
@@ -0,0 +1,331 @@
+/*
+ * SPDX-FileCopyrightText: 2026 Espressif Systems (Shanghai) CO LTD
+ *
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+#include "driver/gpio.h"
+#include "driver/spi_master.h"
+#include "esp_check.h"
+#include "esp_lcd_co5300.h"
+#include "esp_lcd_panel_io.h"
+#include "esp_lcd_panel_ops.h"
+#include "esp_lcd_touch_cst816s.h"
+#include "esp_log.h"
+
+#include "bsp_err_check.h"
+#include "bsp_stopwatch_internal.h"
+#include "bsp/m5stack_stopwatch.h"
+
+static const char *TAG = "M5Stack StopWatch";
+static bool spi_initialized;
+static bsp_lcd_handles_t display_handles;
+static esp_lcd_touch_handle_t touch_handle;
+static esp_lcd_panel_io_handle_t touch_io_handle;
+
+#if (BSP_CONFIG_NO_GRAPHIC_LIB == 0)
+static lv_display_t *display;
+static lv_indev_t *touch_input;
+#endif
+
+static esp_err_t bsp_spi_init(uint32_t max_transfer_size)
+{
+    if (spi_initialized) {
+        return ESP_OK;
+    }
+
+    const spi_bus_config_t bus_config = CO5300_PANEL_BUS_QSPI_CONFIG(
+        BSP_LCD_PCLK, BSP_LCD_DATA0, BSP_LCD_DATA1, BSP_LCD_DATA2, BSP_LCD_DATA3, max_transfer_size);
+    ESP_RETURN_ON_ERROR(spi_bus_initialize(BSP_LCD_SPI_NUM, &bus_config, SPI_DMA_CH_AUTO), TAG,
+                        "Failed to initialize QSPI bus");
+    spi_initialized = true;
+    return ESP_OK;
+}
+
+esp_err_t bsp_display_brightness_init(void)
+{
+    return ESP_OK;
+}
+
+esp_err_t bsp_display_brightness_deinit(void)
+{
+    return ESP_OK;
+}
+
+esp_err_t bsp_display_brightness_set(int brightness_percent)
+{
+    ESP_RETURN_ON_FALSE(display_handles.panel != NULL, ESP_ERR_INVALID_STATE, TAG, "Display is not initialized");
+    if (brightness_percent < 0) {
+        brightness_percent = 0;
+    } else if (brightness_percent > 100) {
+        brightness_percent = 100;
+    }
+    return esp_lcd_panel_co5300_set_brightness(display_handles.panel, brightness_percent);
+}
+
+esp_err_t bsp_display_backlight_on(void)
+{
+    return bsp_display_brightness_set(100);
+}
+
+esp_err_t bsp_display_backlight_off(void)
+{
+    return bsp_display_brightness_set(0);
+}
+
+esp_err_t bsp_display_new(const bsp_display_config_t *config, esp_lcd_panel_handle_t *ret_panel,
+                          esp_lcd_panel_io_handle_t *ret_io)
+{
+    ESP_RETURN_ON_FALSE(ret_panel != NULL && ret_io != NULL, ESP_ERR_INVALID_ARG, TAG, "Display output is NULL");
+    bsp_lcd_handles_t handles = {0};
+    esp_err_t ret = bsp_display_new_with_handles(config, &handles);
+    *ret_panel = handles.panel;
+    *ret_io = handles.io;
+    return ret;
+}
+
+esp_err_t bsp_display_new_with_handles(const bsp_display_config_t *config, bsp_lcd_handles_t *ret_handles)
+{
+    ESP_RETURN_ON_FALSE(config != NULL && config->max_transfer_sz > 0, ESP_ERR_INVALID_ARG, TAG,
+                        "Invalid display config");
+    ESP_RETURN_ON_FALSE(ret_handles != NULL, ESP_ERR_INVALID_ARG, TAG, "Display output is NULL");
+    ESP_RETURN_ON_ERROR(bsp_control_init(), TAG, "Control initialization failed");
+    ESP_RETURN_ON_ERROR(bsp_feature_enable(BSP_FEATURE_LCD, true), TAG, "Failed to enable display");
+    ESP_RETURN_ON_ERROR(bsp_stopwatch_display_reset(), TAG, "Display reset failed");
+    ESP_RETURN_ON_ERROR(bsp_spi_init(config->max_transfer_sz), TAG, "QSPI initialization failed");
+
+    const gpio_config_t te_config = {
+        .pin_bit_mask = BIT64(BSP_LCD_TE),
+        .mode = GPIO_MODE_INPUT,
+        .pull_up_en = GPIO_PULLUP_ENABLE,
+    };
+    ESP_RETURN_ON_ERROR(gpio_config(&te_config), TAG, "Failed to configure display TE pin");
+
+    const esp_lcd_panel_io_spi_config_t io_config = CO5300_PANEL_IO_QSPI_CONFIG(BSP_LCD_CS, NULL, NULL);
+    esp_err_t ret = esp_lcd_new_panel_io_spi((esp_lcd_spi_bus_handle_t)BSP_LCD_SPI_NUM, &io_config, &ret_handles->io);
+    if (ret != ESP_OK) {
+        goto fail;
+    }
+
+    co5300_vendor_config_t vendor_config = {
+        .flags.use_qspi_interface = 1,
+    };
+    const esp_lcd_panel_dev_config_t panel_config = {
+        .reset_gpio_num = BSP_LCD_RST,
+        .rgb_ele_order = BSP_LCD_COLOR_SPACE,
+        .bits_per_pixel = BSP_LCD_BITS_PER_PIXEL,
+        .vendor_config = &vendor_config,
+    };
+    ret = esp_lcd_new_panel_co5300(ret_handles->io, &panel_config, &ret_handles->panel);
+    if (ret != ESP_OK) {
+        goto fail;
+    }
+
+    ret = esp_lcd_panel_reset(ret_handles->panel);
+    if (ret != ESP_OK) {
+        goto fail;
+    }
+    ret = esp_lcd_panel_init(ret_handles->panel);
+    if (ret != ESP_OK) {
+        goto fail;
+    }
+    ret = esp_lcd_panel_set_gap(ret_handles->panel, BSP_LCD_X_GAP, 0);
+    if (ret != ESP_OK) {
+        goto fail;
+    }
+    ret = esp_lcd_panel_swap_xy(ret_handles->panel, false);
+    if (ret != ESP_OK) {
+        goto fail;
+    }
+    ret = esp_lcd_panel_mirror(ret_handles->panel, false, false);
+    if (ret != ESP_OK) {
+        goto fail;
+    }
+
+    display_handles = *ret_handles;
+    ESP_LOGI(TAG, "Display initialized: CO5300 QSPI, %dx%d, x-gap %d",
+             BSP_LCD_H_RES, BSP_LCD_V_RES, BSP_LCD_X_GAP);
+    return ESP_OK;
+
+fail:
+    if (ret_handles->panel != NULL) {
+        esp_lcd_panel_del(ret_handles->panel);
+        ret_handles->panel = NULL;
+    }
+    if (ret_handles->io != NULL) {
+        esp_lcd_panel_io_del(ret_handles->io);
+        ret_handles->io = NULL;
+    }
+    if (spi_initialized) {
+        spi_bus_free(BSP_LCD_SPI_NUM);
+        spi_initialized = false;
+    }
+    return ret;
+}
+
+void bsp_display_delete(void)
+{
+    if (touch_handle != NULL) {
+        esp_lcd_touch_del(touch_handle);
+        touch_handle = NULL;
+    }
+    if (touch_io_handle != NULL) {
+        esp_lcd_panel_io_del(touch_io_handle);
+        touch_io_handle = NULL;
+    }
+    if (display_handles.panel != NULL) {
+        esp_lcd_panel_del(display_handles.panel);
+        display_handles.panel = NULL;
+    }
+    if (display_handles.io != NULL) {
+        esp_lcd_panel_io_del(display_handles.io);
+        display_handles.io = NULL;
+    }
+    if (spi_initialized) {
+        spi_bus_free(BSP_LCD_SPI_NUM);
+        spi_initialized = false;
+    }
+}
+
+esp_err_t bsp_touch_new(const bsp_touch_config_t *config, esp_lcd_touch_handle_t *ret_touch)
+{
+    (void)config;
+    ESP_RETURN_ON_FALSE(ret_touch != NULL, ESP_ERR_INVALID_ARG, TAG, "Touch output is NULL");
+    ESP_RETURN_ON_ERROR(bsp_i2c_init(), TAG, "Failed to initialize I2C");
+    ESP_RETURN_ON_ERROR(bsp_stopwatch_touch_reset(), TAG, "Touch reset failed");
+
+    const esp_lcd_touch_config_t touch_config = {
+        .x_max = BSP_LCD_H_RES,
+        .y_max = BSP_LCD_V_RES,
+        .rst_gpio_num = GPIO_NUM_NC,
+        .int_gpio_num = BSP_LCD_TOUCH_INT,
+        .levels = {
+            .reset = 0,
+            .interrupt = 0,
+        },
+        .flags = {
+            .swap_xy = false,
+            .mirror_x = false,
+            .mirror_y = false,
+        },
+    };
+    const esp_lcd_panel_io_i2c_config_t io_config = ESP_LCD_TOUCH_IO_I2C_CST816S_CONFIG();
+    ESP_RETURN_ON_ERROR(esp_lcd_new_panel_io_i2c(bsp_i2c_get_handle(), &io_config, &touch_io_handle), TAG,
+                        "Failed to create touch I2C IO");
+    esp_err_t ret = esp_lcd_touch_new_i2c_cst816s(touch_io_handle, &touch_config, ret_touch);
+    if (ret != ESP_OK) {
+        esp_lcd_panel_io_del(touch_io_handle);
+        touch_io_handle = NULL;
+        return ret;
+    }
+    touch_handle = *ret_touch;
+    ESP_LOGI(TAG, "Touch initialized: CST820B via CST816S-compatible register interface");
+    return ESP_OK;
+}
+
+#if (BSP_CONFIG_NO_GRAPHIC_LIB == 0)
+static lv_display_t *bsp_display_lcd_init(const bsp_display_cfg_t *config)
+{
+    const bsp_display_config_t low_level_config = {
+        .max_transfer_sz = BSP_LCD_H_RES * CONFIG_BSP_LCD_DRAW_BUF_HEIGHT * sizeof(uint16_t),
+    };
+    BSP_ERROR_CHECK_RETURN_NULL(bsp_display_new(&low_level_config, &display_handles.panel, &display_handles.io));
+    BSP_ERROR_CHECK_RETURN_NULL(esp_lcd_panel_disp_on_off(display_handles.panel, true));
+
+    const lvgl_port_display_cfg_t display_config = {
+        .io_handle = display_handles.io,
+        .panel_handle = display_handles.panel,
+        .buffer_size = config->buffer_size,
+        .double_buffer = config->double_buffer,
+        .hres = BSP_LCD_H_RES,
+        .vres = BSP_LCD_V_RES,
+        .monochrome = false,
+        .rotation = {
+            .swap_xy = false,
+            .mirror_x = false,
+            .mirror_y = false,
+        },
+        .flags = {
+            .buff_dma = config->flags.buff_dma,
+            .buff_spiram = config->flags.buff_spiram,
+#if LVGL_VERSION_MAJOR >= 9
+            .swap_bytes = BSP_LCD_BIGENDIAN,
+#endif
+            .sw_rotate = config->flags.sw_rotate,
+        },
+    };
+    return lvgl_port_add_disp(&display_config);
+}
+
+static lv_indev_t *bsp_display_touch_init(lv_display_t *lv_display)
+{
+    BSP_ERROR_CHECK_RETURN_NULL(bsp_touch_new(NULL, &touch_handle));
+    const lvgl_port_touch_cfg_t touch_config = {
+        .disp = lv_display,
+        .handle = touch_handle,
+    };
+    return lvgl_port_add_touch(&touch_config);
+}
+
+lv_display_t *bsp_display_start(void)
+{
+    const bsp_display_cfg_t config = {
+        .lvgl_port_cfg = ESP_LVGL_PORT_INIT_CONFIG(),
+        .buffer_size = BSP_LCD_H_RES * CONFIG_BSP_LCD_DRAW_BUF_HEIGHT,
+#if CONFIG_BSP_LCD_DRAW_BUF_DOUBLE
+        .double_buffer = true,
+#else
+        .double_buffer = false,
+#endif
+        .flags = {
+            .buff_dma = true,
+            .buff_spiram = false,
+            .sw_rotate = false,
+        },
+    };
+    return bsp_display_start_with_config(&config);
+}
+
+lv_display_t *bsp_display_start_with_config(const bsp_display_cfg_t *config)
+{
+    BSP_NULL_CHECK(config, NULL);
+    BSP_ERROR_CHECK_RETURN_NULL(lvgl_port_init(&config->lvgl_port_cfg));
+    BSP_NULL_CHECK(display = bsp_display_lcd_init(config), NULL);
+    BSP_NULL_CHECK(touch_input = bsp_display_touch_init(display), NULL);
+    return display;
+}
+
+lv_indev_t *bsp_display_get_input_dev(void)
+{
+    return touch_input;
+}
+
+void bsp_display_rotate(lv_display_t *lv_display, lv_display_rotation_t rotation)
+{
+    lv_display_set_rotation(lv_display, rotation);
+}
+
+bool bsp_display_lock(uint32_t timeout_ms)
+{
+    return lvgl_port_lock(timeout_ms);
+}
+
+void bsp_display_unlock(void)
+{
+    lvgl_port_unlock();
+}
+
+esp_err_t bsp_display_enter_sleep(void)
+{
+    ESP_RETURN_ON_FALSE(display_handles.panel != NULL, ESP_ERR_INVALID_STATE, TAG, "Display is not initialized");
+    ESP_RETURN_ON_ERROR(esp_lcd_panel_disp_on_off(display_handles.panel, false), TAG, "Display sleep failed");
+    return bsp_feature_enable(BSP_FEATURE_TOUCH, false);
+}
+
+esp_err_t bsp_display_exit_sleep(void)
+{
+    ESP_RETURN_ON_FALSE(display_handles.panel != NULL, ESP_ERR_INVALID_STATE, TAG, "Display is not initialized");
+    ESP_RETURN_ON_ERROR(bsp_stopwatch_touch_reset(), TAG, "Touch wake failed");
+    return esp_lcd_panel_disp_on_off(display_handles.panel, true);
+}
+#endif
diff --git a/bsp/m5stack_stopwatch/src/bsp_i2c.c b/bsp/m5stack_stopwatch/src/bsp_i2c.c
new file mode 100644
index 0000000..efba653
--- /dev/null
+++ b/bsp/m5stack_stopwatch/src/bsp_i2c.c
@@ -0,0 +1,48 @@
+/*
+ * SPDX-FileCopyrightText: 2026 Espressif Systems (Shanghai) CO LTD
+ *
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+#include "bsp_err_check.h"
+#include "bsp/m5stack_stopwatch.h"
+
+static i2c_master_bus_handle_t i2c_handle;
+static bool i2c_initialized;
+
+esp_err_t bsp_i2c_init(void)
+{
+    if (i2c_initialized) {
+        return ESP_OK;
+    }
+
+    const i2c_master_bus_config_t config = {
+        .i2c_port = BSP_I2C_NUM,
+        .sda_io_num = BSP_I2C_SDA,
+        .scl_io_num = BSP_I2C_SCL,
+        .clk_source = I2C_CLK_SRC_DEFAULT,
+        .flags.enable_internal_pullup = true,
+    };
+    BSP_ERROR_CHECK_RETURN_ERR(i2c_new_master_bus(&config, &i2c_handle));
+    i2c_initialized = true;
+    return ESP_OK;
+}
+
+esp_err_t bsp_i2c_deinit(void)
+{
+    if (!i2c_initialized) {
+        return ESP_OK;
+    }
+    BSP_ERROR_CHECK_RETURN_ERR(i2c_del_master_bus(i2c_handle));
+    i2c_handle = NULL;
+    i2c_initialized = false;
+    return ESP_OK;
+}
+
+i2c_master_bus_handle_t bsp_i2c_get_handle(void)
+{
+    if (bsp_i2c_init() != ESP_OK) {
+        return NULL;
+    }
+    return i2c_handle;
+}
diff --git a/bsp/m5stack_stopwatch/src/bsp_sensors.c b/bsp/m5stack_stopwatch/src/bsp_sensors.c
new file mode 100644
index 0000000..61fa9a7
--- /dev/null
+++ b/bsp/m5stack_stopwatch/src/bsp_sensors.c
@@ -0,0 +1,31 @@
+/*
+ * SPDX-FileCopyrightText: 2026 Espressif Systems (Shanghai) CO LTD
+ *
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+#include "esp_check.h"
+#include "bmi270.h"
+#include "bsp_err_check.h"
+#include "bsp/m5stack_stopwatch.h"
+
+static const char *TAG = "M5Stack StopWatch";
+
+esp_err_t bsp_sensor_init(const bsp_sensor_config_t *cfg, sensor_handle_t *sensor_handle)
+{
+    ESP_RETURN_ON_FALSE(cfg != NULL, ESP_ERR_INVALID_ARG, TAG, "Sensor config is NULL");
+    ESP_RETURN_ON_FALSE(sensor_handle != NULL, ESP_ERR_INVALID_ARG, TAG, "Sensor handle output is NULL");
+    ESP_RETURN_ON_ERROR(bsp_i2c_init(), TAG, "Failed to initialize I2C");
+
+    sensor_config_t config = {
+        .type = cfg->type,
+        .mode = cfg->mode,
+        .min_delay = cfg->period,
+        .bus = bsp_i2c_get_handle(),
+    };
+    if (cfg->type != IMU_ID) {
+        return ESP_ERR_NOT_SUPPORTED;
+    }
+    config.addr = BMI270_I2C_ADDRESS_L;
+    return iot_sensor_create("sensor_hub_bmi270", &config, sensor_handle);
+}
