diff --git a/bsp/m5stack_stopwatch/src/bsp_audio.c b/bsp/m5stack_stopwatch/src/bsp_audio.c
new file mode 100644
index 0000000..84d66e9
--- /dev/null
+++ b/bsp/m5stack_stopwatch/src/bsp_audio.c
@@ -0,0 +1,148 @@
+/*
+ * SPDX-FileCopyrightText: 2026 Espressif Systems (Shanghai) CO LTD
+ *
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+#include "esp_check.h"
+#include "esp_codec_dev_defaults.h"
+#include "bsp_err_check.h"
+#include "bsp/m5stack_stopwatch.h"
+
+static const char *TAG = "M5Stack StopWatch";
+static i2s_chan_handle_t i2s_tx_chan;
+static i2s_chan_handle_t i2s_rx_chan;
+static const audio_codec_data_if_t *i2s_data_if;
+static esp_codec_dev_handle_t codec_handle;
+
+#define BSP_I2S_GPIO_CFG       \
+    {                          \
+        .mclk = BSP_I2S_MCLK,  \
+        .bclk = BSP_I2S_SCLK,  \
+        .ws = BSP_I2S_LCLK,    \
+        .dout = BSP_I2S_DOUT,  \
+        .din = BSP_I2S_DSIN,   \
+        .invert_flags = {      \
+            .mclk_inv = false, \
+            .bclk_inv = false, \
+            .ws_inv = false,   \
+        },                     \
+    }
+
+#define BSP_I2S_DUPLEX_CFG(sample_rate_hz)                                                         \
+    {                                                                                              \
+        .clk_cfg = I2S_STD_CLK_DEFAULT_CONFIG(sample_rate_hz),                                    \
+        .slot_cfg = I2S_STD_PHILIPS_SLOT_DEFAULT_CONFIG(I2S_DATA_BIT_WIDTH_16BIT, I2S_SLOT_MODE_STEREO), \
+        .gpio_cfg = BSP_I2S_GPIO_CFG,                                                             \
+    }
+
+esp_err_t bsp_audio_init(const i2s_std_config_t *i2s_config)
+{
+    if (i2s_data_if != NULL) {
+        return ESP_OK;
+    }
+
+    esp_err_t ret = ESP_FAIL;
+    i2s_chan_config_t channel_config = I2S_CHANNEL_DEFAULT_CONFIG(CONFIG_BSP_I2S_NUM, I2S_ROLE_MASTER);
+    channel_config.auto_clear = true;
+    ESP_GOTO_ON_ERROR(i2s_new_channel(&channel_config, &i2s_tx_chan, &i2s_rx_chan), fail, TAG,
+                      "Failed to create I2S channels");
+
+    const i2s_std_config_t default_config = BSP_I2S_DUPLEX_CFG(44100);
+    const i2s_std_config_t *config = i2s_config != NULL ? i2s_config : &default_config;
+    ESP_GOTO_ON_ERROR(i2s_channel_init_std_mode(i2s_tx_chan, config), fail, TAG, "TX I2S init failed");
+    ESP_GOTO_ON_ERROR(i2s_channel_init_std_mode(i2s_rx_chan, config), fail, TAG, "RX I2S init failed");
+    ESP_GOTO_ON_ERROR(i2s_channel_enable(i2s_tx_chan), fail, TAG, "TX I2S enable failed");
+    ESP_GOTO_ON_ERROR(i2s_channel_enable(i2s_rx_chan), fail, TAG, "RX I2S enable failed");
+
+    audio_codec_i2s_cfg_t codec_i2s_config = {
+        .port = CONFIG_BSP_I2S_NUM,
+        .rx_handle = i2s_rx_chan,
+        .tx_handle = i2s_tx_chan,
+    };
+    i2s_data_if = audio_codec_new_i2s_data(&codec_i2s_config);
+    ESP_GOTO_ON_FALSE(i2s_data_if != NULL, ESP_ERR_NO_MEM, fail, TAG, "Failed to create codec I2S interface");
+    return ESP_OK;
+
+fail:
+    if (i2s_tx_chan != NULL) {
+        i2s_del_channel(i2s_tx_chan);
+        i2s_tx_chan = NULL;
+    }
+    if (i2s_rx_chan != NULL) {
+        i2s_del_channel(i2s_rx_chan);
+        i2s_rx_chan = NULL;
+    }
+    return ret;
+}
+
+const audio_codec_data_if_t *bsp_audio_get_codec_itf(void)
+{
+    return i2s_data_if;
+}
+
+static esp_codec_dev_handle_t bsp_audio_codec_init(void)
+{
+    if (codec_handle != NULL) {
+        return codec_handle;
+    }
+
+    BSP_ERROR_CHECK_RETURN_NULL(bsp_control_init());
+    BSP_ERROR_CHECK_RETURN_NULL(bsp_feature_enable(BSP_FEATURE_AUDIO, true));
+    BSP_ERROR_CHECK_RETURN_NULL(bsp_i2c_init());
+    BSP_ERROR_CHECK_RETURN_NULL(bsp_audio_init(NULL));
+
+    audio_codec_i2c_cfg_t i2c_config = {
+        .port = BSP_I2C_NUM,
+        .addr = ES8311_CODEC_DEFAULT_ADDR,
+        .bus_handle = bsp_i2c_get_handle(),
+    };
+    const audio_codec_ctrl_if_t *control_if = audio_codec_new_i2c_ctrl(&i2c_config);
+    BSP_NULL_CHECK(control_if, NULL);
+    const audio_codec_gpio_if_t *gpio_if = audio_codec_new_gpio();
+    BSP_NULL_CHECK(gpio_if, NULL);
+
+    const esp_codec_dev_hw_gain_t gain = {
+        .pa_voltage = 5.0,
+        .codec_dac_voltage = 3.3,
+    };
+    es8311_codec_cfg_t codec_config = {
+        .ctrl_if = control_if,
+        .gpio_if = gpio_if,
+        .codec_mode = ESP_CODEC_DEV_WORK_MODE_BOTH,
+        .pa_pin = GPIO_NUM_NC,
+        .pa_reverted = false,
+        .master_mode = false,
+        .use_mclk = true,
+        .digital_mic = false,
+        .invert_mclk = false,
+        .invert_sclk = false,
+        .hw_gain = gain,
+    };
+    const audio_codec_if_t *codec_if = es8311_codec_new(&codec_config);
+    BSP_NULL_CHECK(codec_if, NULL);
+
+    esp_codec_dev_cfg_t device_config = {
+        .dev_type = ESP_CODEC_DEV_TYPE_IN_OUT,
+        .codec_if = codec_if,
+        .data_if = i2s_data_if,
+    };
+    codec_handle = esp_codec_dev_new(&device_config);
+    return codec_handle;
+}
+
+esp_codec_dev_handle_t bsp_audio_codec_speaker_init(void)
+{
+    esp_codec_dev_handle_t handle = bsp_audio_codec_init();
+    if (handle == NULL) {
+        return NULL;
+    }
+    BSP_ERROR_CHECK_RETURN_NULL(bsp_feature_enable(BSP_FEATURE_SPEAKER, true));
+    return handle;
+}
+
+esp_codec_dev_handle_t bsp_audio_codec_microphone_init(void)
+{
+    BSP_ERROR_CHECK_RETURN_NULL(bsp_feature_enable(BSP_FEATURE_MIC, true));
+    return bsp_audio_codec_init();
+}
