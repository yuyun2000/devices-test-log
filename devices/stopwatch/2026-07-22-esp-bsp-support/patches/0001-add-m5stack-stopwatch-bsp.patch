index 0000000..e51609b
--- /dev/null
+++ b/bsp/m5stack_stopwatch/idf_component.yml
@@ -0,0 +1,44 @@
+version: "1.0.0"
+description: Board Support Package (BSP) for M5Stack StopWatch
+url: https://github.com/espressif/esp-bsp/tree/master/bsp/m5stack_stopwatch
+
+targets:
+  - esp32s3
+
+tags:
+  - bsp
+  - M5Stack
+
+dependencies:
+  idf: ">=5.4"
+
+  esp_codec_dev:
+    version: "~1.5"
+    public: true
+
+  espressif/esp_lvgl_port:
+    version: "^2"
+    public: true
+    override_path: "../../components/esp_lvgl_port"
+
+  espressif/esp_lcd_co5300:
+    version: "^2.1.0"
+    public: false
+
+  espressif/esp_lcd_touch_cst816s:
+    version: "^1.1.1"
+    public: false
+    override_path: "../../components/lcd_touch/esp_lcd_touch_cst816s"
+
+  espressif/button:
+    version: "^4"
+    public: true
+
+  espressif/bmi270:
+    version: "*"
+    public: true
+    override_path: "../../components/sensors/bmi270"
+
+examples:
+  - path: ../../examples/display
+  - path: ../../examples/display_sensors
