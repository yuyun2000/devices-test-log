+/*
+ * SPDX-FileCopyrightText: 2026 Espressif Systems (Shanghai) CO LTD
+ *
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+/**
+ * @file
+ * @brief ESP BSP: M5Stack StopWatch
+ */
+
+#pragma once
+
+#include <stdbool.h>
+#include <stddef.h>
+#include <stdint.h>
+
+#include "sdkconfig.h"
+#include "driver/gpio.h"
+#include "driver/i2c_master.h"
+#include "driver/i2s_std.h"
+#include "driver/spi_master.h"
+#include "esp_codec_dev.h"
+#include "iot_button.h"
+#include "iot_sensor_hub.h"
+#include "bsp/config.h"
+#include "bsp/display.h"
+#include "bsp/touch.h"
+
+#if (BSP_CONFIG_NO_GRAPHIC_LIB == 0)
+#include "lvgl.h"
+#include "esp_lvgl_port.h"
+#endif
+
+#define BSP_BOARD_M5STACK_STOPWATCH
+
+#define BSP_CAPS_DISPLAY          1
+#define BSP_CAPS_TOUCH            1
+#define BSP_CAPS_BUTTONS          1
+#define BSP_CAPS_KNOB             0
+#define BSP_CAPS_AUDIO            1
+#define BSP_CAPS_AUDIO_SPEAKER    1
+#define BSP_CAPS_AUDIO_MIC        1
+#define BSP_CAPS_SDCARD           0
+#define BSP_CAPS_LED              0
+#define BSP_CAPS_CAMERA           0
+#define BSP_CAPS_BAT              1
+#define BSP_CAPS_IMU              1
+#define BSP_CAPS_HUMITURE         0
+
+/* Shared system I2C bus */
+#define BSP_I2C_NUM                  CONFIG_BSP_I2C_NUM
+#define BSP_I2C_SDA                  (GPIO_NUM_47)
+#define BSP_I2C_SCL                  (GPIO_NUM_48)
+#define BSP_I2C_M5PM1_ADDRESS        (0x6E)
+#define BSP_I2C_M5IOE1_ADDRESS       (0x4F)
+#define BSP_I2C_M5IOE1_ADDRESS_ALT   (0x6F)
+#define BSP_I2C_TOUCH_ADDRESS        (0x15)
+#define BSP_I2C_AUDIO_ADDRESS        (0x18)
+#define BSP_I2C_RTC_ADDRESS          (0x32)
+#define BSP_I2C_IMU_ADDRESS          (0x68)
+
+/* CO5300 QSPI display */
+#define BSP_LCD_SPI_NUM              (SPI2_HOST)
+#define BSP_LCD_PIXEL_CLOCK_HZ       (40 * 1000 * 1000)
+#define BSP_LCD_PCLK                 (GPIO_NUM_40)
+#define BSP_LCD_DATA0                (GPIO_NUM_41)
+#define BSP_LCD_DATA1                (GPIO_NUM_42)
+#define BSP_LCD_DATA2                (GPIO_NUM_46)
+#define BSP_LCD_DATA3                (GPIO_NUM_45)
+#define BSP_LCD_CS                   (GPIO_NUM_39)
+#define BSP_LCD_TE                   (GPIO_NUM_38)
+#define BSP_LCD_RST                  (GPIO_NUM_NC)
+#define BSP_LCD_X_GAP                (6)
+
+/* CST820B touch */
+#define BSP_LCD_TOUCH_INT            (GPIO_NUM_13)
+
+/* ES8311 codec */
+#define BSP_I2S_MCLK                 (GPIO_NUM_18)
+#define BSP_I2S_SCLK                 (GPIO_NUM_17)
+#define BSP_I2S_LCLK                 (GPIO_NUM_15)
+#define BSP_I2S_DOUT                 (GPIO_NUM_21)
+#define BSP_I2S_DSIN                 (GPIO_NUM_16)
+#define BSP_POWER_AMP_IO             (GPIO_NUM_NC)
+
+/* Physical buttons, active low */
+#define BSP_BUTTON_A_IO              (GPIO_NUM_2)
+#define BSP_BUTTON_B_IO              (GPIO_NUM_1)
+
+/* M5IOE1 GPIO numbers use the silkscreen numbering, 1 through 14. */
+#define BSP_IOE_MUX_SELECT           (1)
+#define BSP_IOE_AUDIO_ENABLE         (3)
+#define BSP_IOE_TOUCH_RESET          (4)
+#define BSP_IOE_DISPLAY_RESET        (5)
+#define BSP_IOE_DISPLAY_ENABLE       (8)
+#define BSP_IOE_VIBRATION            (9)
+#define BSP_IOE_SPEAKER_ENABLE       (10)
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+typedef enum {
+    BSP_FEATURE_LCD = 0,
+    BSP_FEATURE_TOUCH,
+    BSP_FEATURE_AUDIO,
+    BSP_FEATURE_SPEAKER,
+    BSP_FEATURE_MIC,
+    BSP_FEATURE_USB,
+    BSP_FEATURE_NUM,
+} bsp_feature_t;
+
+typedef enum {
+    BSP_STOPWATCH_POWER_SOURCE_NONE = 0,
+    BSP_STOPWATCH_POWER_SOURCE_USB = BIT(0),
+    BSP_STOPWATCH_POWER_SOURCE_5V_IN_OUT = BIT(1),
+    BSP_STOPWATCH_POWER_SOURCE_BATTERY = BIT(2),
+    BSP_STOPWATCH_POWER_SOURCE_UNKNOWN = 0xFF,
+} bsp_stopwatch_power_source_t;
+
+typedef enum {
+    BSP_BUTTON_A = 0,
+    BSP_BUTTON_B,
+    BSP_BUTTON_NUM,
+} bsp_button_t;
+
+typedef struct {
+    sensor_type_t type;
+    sensor_mode_t mode;
+    uint32_t period;
+} bsp_sensor_config_t;
+
+esp_err_t bsp_i2c_init(void);
+esp_err_t bsp_i2c_deinit(void);
+i2c_master_bus_handle_t bsp_i2c_get_handle(void);
+
+/** Initialize the PMIC and M5IOE1 power/control domains. */
+esp_err_t bsp_control_init(void);
+
+/** Enable or disable a StopWatch hardware feature. */
+esp_err_t bsp_feature_enable(bsp_feature_t feature, bool enable);
+
+/** Return the detected M5IOE1 address, or zero before successful initialization. */
+uint8_t bsp_io_expander_get_address(void);
+
+/** Route the shared USB/UART mux. true selects USB; false selects UART. */
+esp_err_t bsp_stopwatch_usb_route(bool usb_selected);
+
+/** Set vibration strength from 0 (off) to 100 percent. */
+esp_err_t bsp_stopwatch_vibration_set(uint8_t strength_percent);
+
+esp_err_t bsp_stopwatch_get_battery_voltage(uint16_t *millivolts);
+esp_err_t bsp_stopwatch_get_input_voltage(uint16_t *millivolts);
+/** Return the active M5PM1 power sources as a bitwise combination. */
+esp_err_t bsp_stopwatch_get_power_source(bsp_stopwatch_power_source_t *source);
+
+esp_err_t bsp_audio_init(const i2s_std_config_t *i2s_config);
+const audio_codec_data_if_t *bsp_audio_get_codec_itf(void);
+esp_codec_dev_handle_t bsp_audio_codec_speaker_init(void);
+esp_codec_dev_handle_t bsp_audio_codec_microphone_init(void);
+
+esp_err_t bsp_iot_button_create(button_handle_t btn_array[], int *btn_cnt, int btn_array_size);
+esp_err_t bsp_sensor_init(const bsp_sensor_config_t *cfg, sensor_handle_t *sensor_handle);
+
+#if (BSP_CONFIG_NO_GRAPHIC_LIB == 0)
+typedef struct {
+    lvgl_port_cfg_t lvgl_port_cfg;
+    uint32_t buffer_size;
+    bool double_buffer;
+    struct {
+        unsigned int buff_dma : 1;
+        unsigned int buff_spiram : 1;
+        unsigned int sw_rotate : 1;
+    } flags;
+} bsp_display_cfg_t;
+
+lv_display_t *bsp_display_start(void);
+lv_display_t *bsp_display_start_with_config(const bsp_display_cfg_t *cfg);
+lv_indev_t *bsp_display_get_input_dev(void);
+void bsp_display_rotate(lv_display_t *disp, lv_display_rotation_t rotation);
+bool bsp_display_lock(uint32_t timeout_ms);
+void bsp_display_unlock(void);
+esp_err_t bsp_display_enter_sleep(void);
+esp_err_t bsp_display_exit_sleep(void);
+#endif
+
+#ifdef __cplusplus
+}
+#endif
